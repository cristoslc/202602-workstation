[Appearance]
ColorScheme=Linux
Font=Monospace,12,-1,5,50,0,0,0,0,0

[General]
# zsh path via Nix profile (Steam Deck always uses the deck user)
Command=/home/deck/.nix-profile/bin/zsh
Name=zsh
Parent=FALLBACK/
TerminalColumns=220
TerminalRows=50

[Scrolling]
HistoryMode=2
HistorySize=10000
ScrollBarPosition=2

[Terminal Features]
BlinkingTextEnabled=true
