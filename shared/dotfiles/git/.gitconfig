# Managed by iac-daily-driver-environments.
# Machine-specific settings (user.email, signing key) go in:
#   ~/.config/git/local.gitconfig

[include]
  path = ~/.config/git/local.gitconfig

[init]
  defaultBranch = main

[pull]
  rebase = true

[push]
  autoSetupRemote = true

[diff]
  algorithm = histogram

[merge]
  conflictstyle = zdiff3

[rerere]
  enabled = true
