# Cross-platform shell aliases.

# Navigation
alias ..='cd ..'
alias ...='cd ../..'

# Git
alias g='git'
alias gs='git status'
alias gd='git diff'
alias gl='git log --oneline -20'
alias gco='git checkout'
alias gcb='git checkout -b'

# Safety
alias rm='rm -i'
alias mv='mv -i'
alias cp='cp -i'

# Misc
alias h='history'
alias j='jobs -l'
alias cls='clear'
