#!/usr/bin/env bash
# shellcheck shell=bash
# <bitbar.title>Backup Status</bitbar.title>
# <bitbar.version>v2.0</bitbar.version>
# <bitbar.author>Ansible backups role</bitbar.author>
# <bitbar.desc>Shows restic backup heartbeat status in macOS menu bar</bitbar.desc>
# <swiftbar.hideAbout>true</swiftbar.hideAbout>
# <swiftbar.hideRunInTerminal>true</swiftbar.hideRunInTerminal>
# <swiftbar.hideDisablePlugin>true</swiftbar.hideDisablePlugin>

HEARTBEAT="{{ restic_heartbeat_file }}"
STALE_MINS=60
AGING_MINS=30
BACKREST_URL="http://{{ backrest_port }}"
BACKREST_PORT="{{ backrest_port.split(':')[-1] }}"
PLAN_ID="home-backup"
REPO_ID="b2-backup"

# ── Helper: detect stuck restic processes ────────────────────────────
STUCK_MINS=20  # consider a restic process stuck after this many minutes
restic_is_stuck() {
  local pids elapsed
  pids="$(pgrep -f 'restic.*(backup|snapshots|forget)' 2>/dev/null)" || return 1
  for pid in $pids; do
    elapsed="$(ps -o etime= -p "$pid" 2>/dev/null | tr -d ' ')"
    # etime format: [[dd-]hh:]mm:ss — anything with hours or days is stuck
    if [[ "$elapsed" == *-* || "$elapsed" == *:*:*:* ]]; then
      return 0  # days present → definitely stuck
    fi
    if [[ "$elapsed" == *:*:* ]]; then
      # hh:mm:ss format — extract hours
      local hours="${elapsed%%:*}"
      [[ "$hours" -gt 0 ]] && return 0
    fi
    # mm:ss format — extract minutes
    local mins="${elapsed%%:*}"
    [[ "$mins" -ge "$STUCK_MINS" ]] && return 0
  done
  return 1
}

# ── Helper: check if a backup is currently running ───────────────────
backup_is_running() {
  pgrep -f 'restic.*backup' >/dev/null 2>&1
}

# ── Backup Now action (called via bash= param) ──────────────────────
if [[ "${1:-}" == "--backup-now" ]]; then
  if restic_is_stuck; then
    # Kill stuck restic processes, unlock repo, then trigger backup
    pkill -f '\.local/share/backrest/restic' 2>/dev/null
    sleep 2
    curl -sf -X POST "${BACKREST_URL}/v1.Backrest/DoRepoTask" \
      -H 'Content-Type: application/json' \
      -d "{\"repo_id\":\"${REPO_ID}\",\"task\":\"TASK_UNLOCK\"}" >/dev/null 2>&1
    sleep 1
  fi
  curl -sf -X POST "${BACKREST_URL}/v1.Backrest/Backup" \
    -H 'Content-Type: application/json' \
    -d "{\"value\":\"${PLAN_ID}\"}" >/dev/null 2>&1
  exit 0
fi

# ── Main: render menu bar status ─────────────────────────────────────

if [[ ! -f "$HEARTBEAT" ]]; then
  echo "🔴💾"
  echo "---"
  echo "No heartbeat file — backup never ran | color=red"
  echo "Open Backrest | href=http://localhost:${BACKREST_PORT}"
  exit 0
fi

LAST_LINE="$(tail -1 "$HEARTBEAT")"
LAST_TS="$(echo "$LAST_LINE" | cut -d' ' -f1)"

if LAST_EPOCH="$(TZ=UTC date -j -f "%Y-%m-%dT%H:%M:%SZ" "$LAST_TS" +%s 2>/dev/null)"; then
  NOW_EPOCH="$(date +%s)"
  AGE_SECS="$(( NOW_EPOCH - LAST_EPOCH ))"
  AGE_HOURS="$(( AGE_SECS / 3600 ))"
  AGE_MINS="$(( AGE_SECS / 60 ))"
else
  echo "🔴💾"
  echo "---"
  echo "Cannot parse heartbeat timestamp | color=red"
  echo "Open Backrest | href=http://localhost:${BACKREST_PORT}"
  exit 0
fi

if [[ "$AGE_HOURS" -ge 1 ]]; then
  AGE_LABEL="${AGE_HOURS}h ago"
else
  AGE_LABEL="${AGE_MINS}m ago"
fi

if [[ "$AGE_MINS" -gt "$STALE_MINS" ]]; then
  echo "🔴💾"
  echo "---"
  echo "Stale: last backup ${AGE_LABEL} | color=red"
elif [[ "$AGE_MINS" -gt "$AGING_MINS" ]]; then
  echo "🟡💾"
  echo "---"
  echo "Aging: last backup ${AGE_LABEL} | color=orange"
else
  echo "🟢💾"
  echo "---"
  echo "OK: last backup ${AGE_LABEL} | color=green"
fi

# ── Backup Now (smart: detects stuck processes) ──────────────────────
SELF="$0"
if backup_is_running; then
  if restic_is_stuck; then
    echo "Backup Now (kill stuck + restart) | bash=${SELF} | param1=--backup-now | terminal=false | refresh=true | color=red"
  else
    echo "Backup running… | color=#888888"
  fi
else
  echo "Backup Now | bash=${SELF} | param1=--backup-now | terminal=false | refresh=true"
fi

echo "Open Backrest | href=http://localhost:${BACKREST_PORT}"
echo "---"
echo "Refresh | refresh=true"
