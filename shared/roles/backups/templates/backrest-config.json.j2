{
  "version": 4,
  "modno": 1,
  "instance": "{{ ansible_facts.hostname }}",
  "repos": [
    {
      "id": "b2-backup",
      "uri": "b2:{{ restic_b2_bucket }}:/",
      "guid": "{{ restic_repo_guid }}",
      "password": "{{ restic_repo_password }}",
      "env": [
        "B2_ACCOUNT_ID={{ restic_b2_account_id }}",
        "B2_ACCOUNT_KEY={{ restic_b2_account_key }}"
      ],
{% set repo_flags = [] %}
{% if restic_upload_limit | int > 0 %}
{%   set _ = repo_flags.extend(["--limit-upload", restic_upload_limit | string]) %}
{% endif %}
{% if restic_download_limit | int > 0 %}
{%   set _ = repo_flags.extend(["--limit-download", restic_download_limit | string]) %}
{% endif %}
      "flags": {{ repo_flags | to_json }},
      "prunePolicy": {
        "schedule": {
          "cron": "{{ restic_prune_schedule }}"
        },
        "maxUnusedPercent": 25
      },
      "checkPolicy": {
        "schedule": {
          "cron": "0 4 1 * *"
        },
        "readDataSubsetPercent": 5
      }
    }
  ],
  "plans": [
    {
      "id": "home-backup",
      "repo": "b2-backup",
      "paths": {{ _restic_verified_paths | to_json }},
      "excludes": {{ (restic_excludes + restic_extra_excludes) | to_json }},
      "iexcludes": [],
      "schedule": {
        "cron": "{{ restic_backup_schedule }}"
      },
      "retention": {
        "policyTimeBucketed": {
          "daily": {{ restic_keep_daily }},
          "weekly": {{ restic_keep_weekly }},
          "monthly": {{ restic_keep_monthly }},
          "yearly": {{ restic_keep_yearly }}
        }
      },
      "hooks": [
        {
          "conditions": ["CONDITION_SNAPSHOT_END"],
          "actionCommand": {
            "command": "/bin/bash -c 'mkdir -p \"$(dirname {{ restic_heartbeat_file }})\" && echo \"$(date -u +%Y-%m-%dT%H:%M:%SZ) {{ ansible_facts.hostname }} snapshot_end\" >> {{ restic_heartbeat_file }}'"
          }
        },
        {
          "conditions": ["CONDITION_SNAPSHOT_ERROR"],
          "actionCommand": {
{% if ansible_facts.os_family == "Darwin" %}
            "command": "osascript -e 'display notification \"Backup failed — check Backrest at localhost:{{ backrest_port.split(':')[-1] }}\" with title \"Restic Backup Error\"'"
{% else %}
            "command": "notify-send -u critical 'Restic Backup Error' 'Backup failed — check Backrest at localhost:{{ backrest_port.split(':')[-1] }}'"
{% endif %}
          }
        }
{% if restic_shoutrrr_url | length > 0 %}
        ,{
          "conditions": ["CONDITION_SNAPSHOT_ERROR"],
          "actionShoutrrr": {
            "shouttrrUrl": "{{ restic_shoutrrr_url }}",
            "template": "Restic backup failed on {{ '{{' }} .hostname {{ '}}' }}"
          },
          "onError": "ON_ERROR_IGNORE"
        }
{% endif %}
      ]
    }
  ],
  "auth": {
    "disabled": true
  }
}
