# Restic exclude patterns — managed by Ansible backups role.
# Do not edit manually; changes will be overwritten on next apply.
#
# Backup strategy: positive inclusion (only explicit paths are backed up).
# These excludes filter within those included paths.
{% for pattern in restic_excludes %}
{{ pattern }}
{% endfor %}
{% if restic_extra_excludes | length > 0 %}

# ── User-defined extra excludes ───────────────────────────
{% for pattern in restic_extra_excludes %}
{{ pattern }}
{% endfor %}
{% endif %}
