<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.workstation.git-repo-scanner</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>$HOME/.local/bin/git-repo-scanner --scan-and-watch</string>
    </array>
    <!-- Run at login and restart if crashed -->
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/git-repo-scanner-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/git-repo-scanner-stderr.log</string>
</dict>
</plist>
