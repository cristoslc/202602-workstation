#!/usr/bin/env bash
# extend-display — create or tear down a virtual display for Sunshine/Moonlight streaming.
# Provisioned by the display Ansible role. See DESIGN-001 for the full workflow.
#
# Usage:
#   extend-display start [WIDTHxHEIGHT] [POSITION]
#   extend-display stop
#   extend-display status
#
# Examples:
#   extend-display start                    # 1920x1080, right of primary
#   extend-display start 2560x1440          # custom resolution
#   extend-display start 1920x1080 --left   # left of primary
#   extend-display stop                     # tear down virtual display

set -euo pipefail

RESOLUTION="${2:-1920x1080}"
POSITION="${3:---right-of}"
VIRTUAL_OUTPUT=""

# Detect the virtual output name based on GPU driver
detect_virtual_output() {
    # Intel: VIRTUAL1 or VIRTUAL2
    if xrandr --query 2>/dev/null | grep -q "VIRTUAL1"; then
        VIRTUAL_OUTPUT="VIRTUAL1"
        return 0
    fi
    # Check for any disconnected virtual output
    local candidate
    candidate=$(xrandr --query 2>/dev/null | grep "VIRTUAL" | head -1 | awk '{print $1}')
    if [[ -n "$candidate" ]]; then
        VIRTUAL_OUTPUT="$candidate"
        return 0
    fi
    return 1
}

# Get the name of the primary display
get_primary() {
    xrandr --query | grep " primary" | awk '{print $1}'
}

cmd_start() {
    if ! detect_virtual_output; then
        echo "error: no virtual output found. Your GPU may not support xrandr virtual outputs." >&2
        echo "       Intel GPUs work out of the box. AMD/Nvidia may need the Linux-Virtual-Display-Driver." >&2
        echo "       See: https://github.com/VirtualDrivers/Linux-Virtual-Display-Driver" >&2
        exit 1
    fi

    local primary
    primary=$(get_primary)

    # Generate modeline if needed
    local modeline
    modeline=$(cvt "${RESOLUTION%%x*}" "${RESOLUTION##*x}" 60 2>/dev/null | grep Modeline | sed 's/Modeline //')
    local mode_name
    mode_name=$(echo "$modeline" | awk '{print $1}' | tr -d '"')

    # Add mode and enable the virtual output
    xrandr --newmode $modeline 2>/dev/null || true
    xrandr --addmode "$VIRTUAL_OUTPUT" "$mode_name" 2>/dev/null || true
    xrandr --output "$VIRTUAL_OUTPUT" --mode "$mode_name" "$POSITION" "$primary"

    echo "Virtual display $VIRTUAL_OUTPUT enabled at $RESOLUTION ($POSITION $primary)"
    echo "Open Moonlight on the receiving device and connect to this machine."
}

cmd_stop() {
    if ! detect_virtual_output; then
        echo "No virtual output found — nothing to tear down."
        exit 0
    fi

    # Get the current mode before turning off
    local current_mode
    current_mode=$(xrandr --query | grep -A1 "^${VIRTUAL_OUTPUT}" | tail -1 | awk '{print $1}')

    xrandr --output "$VIRTUAL_OUTPUT" --off
    if [[ -n "$current_mode" && "$current_mode" != "--" ]]; then
        xrandr --delmode "$VIRTUAL_OUTPUT" "$current_mode" 2>/dev/null || true
    fi

    echo "Virtual display $VIRTUAL_OUTPUT disabled."
}

cmd_status() {
    if ! detect_virtual_output; then
        echo "No virtual output available on this system."
        exit 0
    fi

    local state
    state=$(xrandr --query | grep "^${VIRTUAL_OUTPUT}" | awk '{print $2}')
    if [[ "$state" == "connected" ]]; then
        local mode
        mode=$(xrandr --query | grep -A1 "^${VIRTUAL_OUTPUT}" | tail -1 | awk '{print $1}')
        echo "$VIRTUAL_OUTPUT: active ($mode)"
    else
        echo "$VIRTUAL_OUTPUT: inactive"
    fi
}

case "${1:-}" in
    start)  cmd_start ;;
    stop)   cmd_stop ;;
    status) cmd_status ;;
    *)
        echo "Usage: extend-display {start|stop|status} [WIDTHxHEIGHT] [POSITION]" >&2
        exit 1
        ;;
esac
