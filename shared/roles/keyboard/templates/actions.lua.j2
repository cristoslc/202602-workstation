-- Action bindings — generated by Ansible from the workstation_actions registry.
-- Do not edit manually; changes will be overwritten on next bootstrap.
-- To change bindings, edit shared/roles/keyboard/defaults/main.yml.

{% for action in workstation_actions if action.implementation.macos is defined and action.implementation.macos.type == 'hammerspoon' %}
-- {{ action.description }}
hs.hotkey.bind({ {{ action.keybinding.macos.mods | map('to_json') | join(', ') }} }, {{ action.keybinding.macos.key | to_json }}, function()
{{ action.implementation.macos.lua | indent(2, first=true) }}
end)

{% endfor %}
