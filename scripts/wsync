#!/usr/bin/env bash
# shellcheck shell=bash
# wsync — Branch-aware code sync wrapper for Unison.
#
# Syncs working trees (excluding .git/) to a hub server, keyed by <repo>/<branch>.
# Each branch gets an isolated directory on the server so switching branches on
# one machine does not affect another machine's working tree.
#
# Usage:
#   wsync                     # auto-discover and sync all git repos under CODE_DIR
#   wsync <repo-dir>          # sync a specific repo
#   wsync --status            # show sync status for all repos
#   wsync --version           # show Unison version info
#
# Configuration (environment variables or ~/.config/wsync/config):
#   WSYNC_CODE_DIR    — local directory containing git repos (default: ~/code)
#   WSYNC_EXTRA_DIRS  — colon-separated additional directories to scan
#   WSYNC_HUB_HOST    — SSH destination for hub server
#   WSYNC_HUB_BASE    — hub-side base directory (default: /srv/code-sync)
#   WSYNC_PROFILE     — Unison profile name (default: code-sync)
#
# Additional sources:
#   ~/.config/wsync/detected-repos  — journal from git-repo-scanner (SPEC-002)
#   ~/.config/wsync/extra-dirs      — one directory per line
set -euo pipefail

# ---------------------------------------------------------------------------
# Source guard for testability
# ---------------------------------------------------------------------------
_WSYNC_SOURCED=1
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  _WSYNC_SOURCED=0
fi

# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------
WSYNC_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/wsync"
WSYNC_CONFIG_FILE="${WSYNC_CONFIG_DIR}/config"

# Load config file if it exists
# shellcheck source=/dev/null
[[ -f "$WSYNC_CONFIG_FILE" ]] && source "$WSYNC_CONFIG_FILE"

WSYNC_CODE_DIR="${WSYNC_CODE_DIR:-$HOME/code}"
WSYNC_EXTRA_DIRS="${WSYNC_EXTRA_DIRS:-}"
WSYNC_HUB_HOST="${WSYNC_HUB_HOST:-}"
WSYNC_HUB_BASE="${WSYNC_HUB_BASE:-/srv/code-sync}"
WSYNC_PROFILE="${WSYNC_PROFILE:-code-sync}"
WSYNC_LOG_DIR="${HOME}/.local/log"
WSYNC_LOG_FILE="${WSYNC_LOG_DIR}/wsync.log"
WSYNC_JOURNAL="${WSYNC_CONFIG_DIR}/detected-repos"
WSYNC_EXTRA_DIRS_FILE="${WSYNC_CONFIG_DIR}/extra-dirs"

# Minimum required Unison major.minor version
WSYNC_UNISON_MIN_VERSION="2.53"

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
wsync_log() {
  local level="$1"
  shift
  local timestamp
  timestamp="$(date '+%Y-%m-%d %H:%M:%S')"
  local msg="[$timestamp] [$level] $*"
  echo "$msg"
  if [[ -d "$WSYNC_LOG_DIR" ]]; then
    echo "$msg" >> "$WSYNC_LOG_FILE"
  fi
}

wsync_info()  { wsync_log INFO  "$@"; }
wsync_warn()  { wsync_log WARN  "$@"; }
wsync_error() { wsync_log ERROR "$@"; }

# ---------------------------------------------------------------------------
# Preflight checks
# ---------------------------------------------------------------------------
wsync_check_unison() {
  if ! command -v unison &>/dev/null; then
    wsync_error "Unison not found. Install via: make apply ROLE=unison"
    return 1
  fi

  local version_output
  version_output="$(unison -version 2>&1)"
  local version
  version="$(echo "$version_output" | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)"

  if [[ -z "$version" ]]; then
    wsync_warn "Could not parse Unison version from: $version_output"
    return 0
  fi

  local major_minor="${version%.*}"
  if [[ "$major_minor" != "$WSYNC_UNISON_MIN_VERSION" ]]; then
    wsync_error "Unison version mismatch: found $version, need ${WSYNC_UNISON_MIN_VERSION}.x"
    wsync_error "All machines must run the same Unison version."
    return 1
  fi

  wsync_info "Unison version: $version"
}

wsync_check_hub() {
  if [[ -z "$WSYNC_HUB_HOST" ]]; then
    wsync_error "WSYNC_HUB_HOST is not set."
    wsync_error "Configure in $WSYNC_CONFIG_FILE or set the environment variable."
    return 1
  fi

  if ! ssh -o BatchMode=yes -o ConnectTimeout=5 "$WSYNC_HUB_HOST" true 2>/dev/null; then
    wsync_error "Cannot connect to hub server '$WSYNC_HUB_HOST' via SSH."
    wsync_error "Ensure SSH key auth is configured and the host is reachable."
    return 1
  fi
}

# ---------------------------------------------------------------------------
# Git helpers
# ---------------------------------------------------------------------------
wsync_get_branch() {
  local repo_dir="$1"
  git -C "$repo_dir" symbolic-ref --short HEAD 2>/dev/null || \
    git -C "$repo_dir" rev-parse --short HEAD 2>/dev/null || \
    echo "unknown"
}

wsync_get_repo_name() {
  local repo_dir="$1"
  basename "$repo_dir"
}

# Get qualified name for a repo on the hub. Repos from WSYNC_CODE_DIR
# use their basename (backward compatible). Repos from other locations
# use parent--basename format to avoid collisions.
# E.g., ~/code/myrepo -> myrepo
#        ~/Documents/HouseOps -> documents--HouseOps
wsync_get_qualified_name() {
  local repo_dir="$1"
  local code_dir
  code_dir="$(cd "$WSYNC_CODE_DIR" 2>/dev/null && pwd -P || echo "$WSYNC_CODE_DIR")"
  local repo_real
  repo_real="$(cd "$repo_dir" 2>/dev/null && pwd -P || echo "$repo_dir")"

  if [[ "$repo_real" == "$code_dir"/* ]]; then
    # Repo is under WSYNC_CODE_DIR: use basename for backward compat
    basename "$repo_dir"
  else
    # Repo is outside WSYNC_CODE_DIR: use parent--basename
    local parent_name
    parent_name="$(basename "$(dirname "$repo_dir")")"
    local repo_name
    repo_name="$(basename "$repo_dir")"
    local parent_lower
    parent_lower="$(echo "$parent_name" | tr '[:upper:]' '[:lower:]')"
    echo "${parent_lower}--${repo_name}"
  fi
}

# Get the source label for a repo (for --status display).
wsync_get_source() {
  local repo_dir="$1"
  local code_dir
  code_dir="$(cd "$WSYNC_CODE_DIR" 2>/dev/null && pwd -P || echo "$WSYNC_CODE_DIR")"
  local repo_real
  repo_real="$(cd "$repo_dir" 2>/dev/null && pwd -P || echo "$repo_dir")"

  if [[ "$repo_real" == "$code_dir"/* ]]; then
    # shellcheck disable=SC2088
    echo "~/code/"
  elif [[ -f "$WSYNC_JOURNAL" ]] && grep -q "^${repo_dir}	" "$WSYNC_JOURNAL" 2>/dev/null; then
    echo "journal"
  else
    echo "extra"
  fi
}

# Discover repos from a single directory (one level deep).
wsync_discover_repos() {
  local code_dir="$1"
  local dir

  if [[ ! -d "$code_dir" ]]; then
    wsync_warn "Code directory does not exist: $code_dir"
    return
  fi

  for dir in "$code_dir"/*/; do
    [[ -d "$dir/.git" ]] && echo "${dir%/}"
  done
}

# Discover ALL repos: CODE_DIR + journal + extra-dirs + WSYNC_EXTRA_DIRS.
# Output: one absolute repo path per line (deduplicated).
wsync_discover_all_repos() {
  local seen_file
  seen_file="$(mktemp)"
  trap 'rm -f "$seen_file"' RETURN

  # Helper: emit path if not already seen
  _emit() {
    local path="$1"
    [[ -d "$path/.git" ]] || return 0
    local real
    real="$(cd "$path" 2>/dev/null && pwd -P || echo "$path")"
    if ! grep -qxF "$real" "$seen_file" 2>/dev/null; then
      echo "$real" >> "$seen_file"
      echo "$path"
    fi
  }

  # 1. WSYNC_CODE_DIR (primary)
  if [[ -d "$WSYNC_CODE_DIR" ]]; then
    local dir
    for dir in "$WSYNC_CODE_DIR"/*/; do
      _emit "${dir%/}"
    done
  fi

  # 2. Detection journal (from git-repo-scanner / SPEC-002)
  if [[ -f "$WSYNC_JOURNAL" ]]; then
    while IFS=$'\t' read -r path _rest; do
      [[ -z "$path" ]] && continue
      [[ "$path" == \#* ]] && continue
      _emit "$path"
    done < "$WSYNC_JOURNAL"
  fi

  # 3. Extra dirs file (~/.config/wsync/extra-dirs)
  if [[ -f "$WSYNC_EXTRA_DIRS_FILE" ]]; then
    while IFS= read -r extra_dir; do
      [[ -z "$extra_dir" ]] && continue
      [[ "$extra_dir" == \#* ]] && continue
      local d
      for d in "$extra_dir"/*/; do
        _emit "${d%/}"
      done
    done < "$WSYNC_EXTRA_DIRS_FILE"
  fi

  # 4. WSYNC_EXTRA_DIRS env var (colon-separated)
  if [[ -n "$WSYNC_EXTRA_DIRS" ]]; then
    IFS=: read -ra extra_dirs <<< "$WSYNC_EXTRA_DIRS"
    local ed
    for ed in "${extra_dirs[@]}"; do
      [[ -z "$ed" ]] && continue
      local d
      for d in "$ed"/*/; do
        _emit "${d%/}"
      done
    done
  fi
}

# ---------------------------------------------------------------------------
# Sync logic
# ---------------------------------------------------------------------------
wsync_sync_repo() {
  local repo_dir="$1"
  local qualified_name branch hub_path

  qualified_name="$(wsync_get_qualified_name "$repo_dir")"
  branch="$(wsync_get_branch "$repo_dir")"

  # Sanitize branch name for filesystem (replace / with _)
  local safe_branch="${branch//\//_}"

  hub_path="${WSYNC_HUB_BASE}/${qualified_name}/${safe_branch}"

  wsync_info "Syncing $qualified_name (branch: $branch) -> $WSYNC_HUB_HOST:$hub_path"

  # Ensure hub-side directory exists
  ssh "$WSYNC_HUB_HOST" "mkdir -p '$hub_path'"

  # Run Unison with the code-sync profile and dynamic roots
  unison "$WSYNC_PROFILE" \
    -root "$repo_dir" \
    -root "ssh://$WSYNC_HUB_HOST/$hub_path" \
    -batch \
    -auto \
    -times \
    -prefer newer \
    -logfile "$WSYNC_LOG_DIR/unison-${qualified_name}-${safe_branch}.log" \
    2>&1 | while IFS= read -r line; do
      wsync_info "  [$qualified_name] $line"
    done

  local rc=${PIPESTATUS[0]}
  if [[ "$rc" -eq 0 ]]; then
    wsync_info "Sync complete: $qualified_name ($branch)"
  else
    wsync_warn "Sync finished with warnings for $qualified_name ($branch) (exit code: $rc)"
  fi

  return "$rc"
}

wsync_sync_all() {
  local repos failed=0

  wsync_info "=== wsync started ==="
  wsync_info "Code directory: $WSYNC_CODE_DIR"
  wsync_info "Hub: $WSYNC_HUB_HOST:$WSYNC_HUB_BASE"

  local repos=()
  while IFS= read -r repo; do
    [[ -n "$repo" ]] && repos+=("$repo")
  done < <(wsync_discover_all_repos)

  if [[ ${#repos[@]} -eq 0 ]]; then
    wsync_warn "No git repositories found"
    return 0
  fi

  wsync_info "Found ${#repos[@]} repositories"

  for repo in "${repos[@]}"; do
    if ! wsync_sync_repo "$repo"; then
      ((failed++))
    fi
  done

  wsync_info "=== wsync finished (${#repos[@]} repos, $failed failed) ==="
  return "$failed"
}

# ---------------------------------------------------------------------------
# Status display
# ---------------------------------------------------------------------------
wsync_status() {
  local repos

  echo "wsync status"
  echo "============"
  echo "Hub:        ${WSYNC_HUB_HOST:-<not configured>}"
  echo "Code dir:   $WSYNC_CODE_DIR"
  echo "Profile:    $WSYNC_PROFILE"
  echo ""

  local repos=()
  while IFS= read -r repo; do
    [[ -n "$repo" ]] && repos+=("$repo")
  done < <(wsync_discover_all_repos)

  if [[ ${#repos[@]} -eq 0 ]]; then
    echo "No git repositories found"
    return 0
  fi

  printf "%-30s %-25s %-10s %s\n" "REPOSITORY" "BRANCH" "STATUS" "SOURCE"
  printf "%-30s %-25s %-10s %s\n" "----------" "------" "------" "------"

  for repo in "${repos[@]}"; do
    local qname branch dirty source
    qname="$(wsync_get_qualified_name "$repo")"
    branch="$(wsync_get_branch "$repo")"
    source="$(wsync_get_source "$repo")"
    if git -C "$repo" diff --quiet 2>/dev/null && git -C "$repo" diff --cached --quiet 2>/dev/null; then
      dirty="clean"
    else
      dirty="modified"
    fi
    printf "%-30s %-25s %-10s %s\n" "$qname" "$branch" "$dirty" "$source"
  done
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------
wsync_usage() {
  cat <<'EOF'
Usage: wsync [OPTIONS] [<repo-dir>]

Branch-aware code sync between workstations via Unison.

Commands:
  wsync                  Sync all discovered git repos
  wsync <repo-dir>       Sync a specific repository
  wsync --status         Show sync status for all repos
  wsync --version        Show Unison version info
  wsync --help           Show this help message

Repo discovery sources (in order):
  1. $WSYNC_CODE_DIR (default: ~/code)
  2. ~/.config/wsync/detected-repos (journal from git-repo-scanner)
  3. ~/.config/wsync/extra-dirs (one directory per line)
  4. $WSYNC_EXTRA_DIRS (colon-separated directories)

Environment:
  WSYNC_CODE_DIR    Primary code directory (default: ~/code)
  WSYNC_EXTRA_DIRS  Additional directories (colon-separated)
  WSYNC_HUB_HOST    Hub server SSH destination
  WSYNC_HUB_BASE    Hub base path (default: /srv/code-sync)
  WSYNC_PROFILE     Unison profile (default: code-sync)

Config file: ~/.config/wsync/config
EOF
}

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------
wsync_main() {
  mkdir -p "$WSYNC_LOG_DIR"

  case "${1:-}" in
    --help|-h)
      wsync_usage
      exit 0
      ;;
    --version|-V)
      wsync_check_unison
      exit $?
      ;;
    --status|-s)
      wsync_status
      exit 0
      ;;
    "")
      # Sync all repos
      wsync_check_unison
      wsync_check_hub
      wsync_sync_all
      ;;
    *)
      # Sync specific repo
      local repo_dir="$1"
      if [[ ! -d "$repo_dir/.git" ]]; then
        wsync_error "'$repo_dir' is not a git repository"
        exit 1
      fi
      wsync_check_unison
      wsync_check_hub
      wsync_sync_repo "$repo_dir"
      ;;
  esac
}

if [[ "$_WSYNC_SOURCED" -eq 0 ]]; then
  wsync_main "$@"
fi
