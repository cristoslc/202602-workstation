<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Stream Deck Plugins</title>
<style>
  :root {
    --bg: #1e1e2e;
    --surface: #282a3a;
    --border: #3b3d52;
    --text: #cdd6f4;
    --dim: #7f849c;
    --accent: #89b4fa;
    --green: #a6e3a1;
    --code-bg: #313244;
  }
  @media (prefers-color-scheme: light) {
    :root {
      --bg: #f5f5f5;
      --surface: #ffffff;
      --border: #d4d4d8;
      --text: #27272a;
      --dim: #71717a;
      --accent: #2563eb;
      --green: #16a34a;
      --code-bg: #e4e4e7;
    }
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    padding: 2rem;
    max-width: 720px;
    margin: 0 auto;
  }
  h1 {
    font-size: 1.5rem;
    margin-bottom: 0.25rem;
    color: var(--accent);
  }
  .meta {
    color: var(--dim);
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
    padding-bottom: 1rem;
  }
  .meta span { display: inline-block; margin-right: 1.5rem; }
  .plugin-list {
    list-style: none;
  }
  .plugin {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .plugin-info {
    flex: 1;
    min-width: 0;
  }
  .plugin-name {
    font-weight: 600;
    color: var(--text);
  }
  .plugin-version {
    color: var(--dim);
    font-size: 0.85rem;
    margin-left: 0.5rem;
  }
  .plugin-uuid {
    color: var(--dim);
    font-size: 0.8rem;
    font-family: "SF Mono", "Fira Code", "JetBrains Mono", monospace;
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .plugin-link {
    flex-shrink: 0;
    color: var(--accent);
    text-decoration: none;
    font-size: 0.85rem;
    padding: 0.3rem 0.75rem;
    border: 1px solid var(--accent);
    border-radius: 6px;
    transition: background 0.15s, color 0.15s;
  }
  .plugin-link:hover {
    background: var(--accent);
    color: var(--bg);
  }
  .plugin-link--search {
    color: var(--dim);
    border-color: var(--dim);
  }
  .plugin-link--search:hover {
    background: var(--dim);
    color: var(--bg);
  }
  .footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border);
    color: var(--dim);
    font-size: 0.8rem;
  }
  .empty {
    color: var(--dim);
    font-style: italic;
    padding: 2rem;
    text-align: center;
  }
</style>
</head>
<body>

<h1>Stream Deck Plugins</h1>
<div class="meta">
  <span>Exported: {{ timestamp }}</span>
  <span>Plugins: <strong>{{ plugins | length }}</strong></span>
</div>

<p style="color: var(--dim); margin-bottom: 1rem;">
  After restoring a Stream Deck backup, reinstall each plugin below.
</p>

{% if plugins %}
<ul class="plugin-list">
  {% for p in plugins %}
  <li class="plugin">
    <div class="plugin-info">
      <span class="plugin-name">{{ p.name }}</span>
      <span class="plugin-version">v{{ p.version }}</span>
      <span class="plugin-uuid">{{ p.uuid }}</span>
    </div>
    {% if p.url == 'https://marketplace.elgato.com/stream-deck/plugins' %}
    <a class="plugin-link plugin-link--search" href="{{ p.url }}" target="_blank" rel="noopener">Search</a>
    {% else %}
    <a class="plugin-link" href="{{ p.url }}" target="_blank" rel="noopener">Install</a>
    {% endif %}
  </li>
  {% endfor %}
</ul>
{% else %}
<div class="empty">No plugins found.</div>
{% endif %}

<div class="footer">
  <p>Open each link to install the plugin from the Elgato Marketplace or vendor site.</p>
</div>

</body>
</html>
